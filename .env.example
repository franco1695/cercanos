# Copia este archivo como ".env" y completa los valores antes de correr el proyecto.

# Clave secreta para firmar las sesiones (JWT). Usa un valor largo y aleatorio.
# Puedes generar uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_valor_secreto_y_largo

# Puerto en el que corre el servidor (la mayoría de hostings lo asignan solos, puedes dejarlo)
PORT=3000

# Credenciales de tu app de Facebook (developers.facebook.com) para "Continuar con Facebook".
# Si las dejas vacías, el login normal (email/contraseña) sigue funcionando igual;
# solo el botón de Facebook mostrará un error hasta que las completes.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
